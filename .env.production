# Production Environment Variables for React Client
# Copy this file to .env.production and update the values

# API URL - Update this to your production backend URL
REACT_APP_API_URL=https://your-backend-service.onrender.com/api/v1

# Optional: Enable analytics in production
REACT_APP_ENABLE_ANALYTICS=false

# Optional: Enable live chat
REACT_APP_ENABLE_LIVE_CHAT=false
